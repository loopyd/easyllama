{
  "container": {
    "image_name": "llamacpp-local:cuda13",
    "container_name": "llamacpp-server",
    "models_dir": "models"
  },
  "network": {
    "host_port": 8080,
    "container_port": 8080,
    "server_host": "0.0.0.0"
  },
  "logging": {
    "log_level": "info",
    "no_color": false
  },
  "locale": {
    "host_tz": "UTC",
    "host_lang": "C.UTF-8",
    "host_lc_all": "C.UTF-8"
  },
  "build": {
    "default_cuda_architectures": "120",
    "cmake_cuda_architectures": "auto",
    "llama_cpp_repo": "https://github.com/ggml-org/llama.cpp.git",
    "llama_cpp_ref": "master"
  },
  "model": {
    "hf_model": "user/repo-name:QUANT_TYPE",
    "hf_token": ""
  },
  "inference": {
    "ctx_size": 125000,
    "temp": 0.6,
    "top_p": 0.95,
    "top_k": 20,
    "min_p": 0.01,
    "repeat_penalty": 1.05,
    "presence_penalty": 0.0,
    "batch_size": 2048,
    "ubatch_size": 512,
    "parallel": 1,
    "n_cpu_moe": 2,
    "fit": "on",
    "flash_attn": "on",
    "cache_type_k": "q8_0",
    "cache_type_v": "q8_0",
    "kv_unified": false,
    "cache_idle_slots": false,
    "no_mmap": true,
    "poll": 1,
    "jinja": true,
    "chat_template_kwargs": {
      "preserve_thinking": false
    },
    "extra_server_args": []
  },
  "reasoning": {
    "enable": "off",
    "format": "auto",
    "budget": 256,
    "budget_message": "Answer directly and avoid long hidden reasoning loops."
  }
}
