{
  "image_name": "llamacpp-local:cuda13",
  "container_name": "llamacpp-server",
  "models_dir": "models",
  "host_port": 8080,
  "container_port": 8080,
  "log_level": "info",
  "no_color": false,
  "host_tz": "UTC",
  "host_lang": "C.UTF-8",
  "host_lc_all": "C.UTF-8",
  "default_cuda_architectures": "120",
  "cmake_cuda_architectures": "auto",
  "hf_model": "mradermacher/Qwen3.6-35B-A3B-abliterated-MAX-i1-GGUF:i1-Q6_K",
  "hf_token": "",
  "server_host": "0.0.0.0",
  "ctx_size": 125000,
  "temp": 0.6,
  "top_p": 0.95,
  "top_k": 20,
  "min_p": 0.01,
  "repeat_penalty": 1.05,
  "presence_penalty": 0.0,
  "batch_size": 2048,
  "ubatch_size": 512,
  "parallel": 1,
  "n_cpu_moe": 2,
  "fit": "on",
  "flash_attn": "on",
  "cache_type_k": "q8_0",
  "cache_type_v": "q8_0",
  "no_mmap": true,
  "poll": 1,
  "jinja": true,
  "chat_template_kwargs": {
    "preserve_thinking": false
  },
  "enable_reasoning": "off",
  "reasoning_format": "auto",
  "reasoning_budget": 256,
  "reasoning_budget_message": "Answer directly and avoid long hidden reasoning loops.",
  "extra_server_args": []
}
