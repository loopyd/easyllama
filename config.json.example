{
  "container": {
    "image_name": "llamacpp-local:cuda13",
    "container_name": "llamacpp-server",
    "models_dir": "models",
    "chat_template_dir": "chat_template",
    "mmproj_dir": "mmproj"
  },
  "network": {
    "host_port": 8080,
    "container_port": 8080,
    "server_host": "0.0.0.0"
  },
  "logging": {
    "log_level": "info",
    "no_color": false
  },
  "locale": {
    "host_tz": "UTC",
    "host_lang": "C.UTF-8",
    "host_lc_all": "C.UTF-8"
  },
  "build": {
    "default_cuda_architectures": "120",
    "cmake_cuda_architectures": "auto",
    "llama_cpp_repo": "https://github.com/ggml-org/llama.cpp.git",
    "llama_cpp_ref": "master"
  },
  "model": {
    "hf_model": "user/repo-name:QUANT_TYPE",
    "hf_token": "",
    "hf_mmproj": ""
  },
  "inference": {
    "ctx_size": 0,
    "threads": 8,
    "threads_batch": 16,
    "n_predict": -1,
    "temp": 0.8,
    "dynatemp_range": 0.0,
    "dynatemp_exp": 1.0,
    "top_p": 0.95,
    "top_k": 40,
    "min_p": 0.05,
    "top_n_sigma": -1.0,
    "xtc_probability": 0.0,
    "xtc_threshold": 0.1,
    "typical_p": 1.0,
    "samplers": "",
    "sampler_seq": "edskypmxt",
    "repeat_last_n": 64,
    "repeat_penalty": 1.0,
    "presence_penalty": 0.0,
    "frequency_penalty": 0.0,
    "dry_multiplier": 0.0,
    "dry_base": 1.75,
    "dry_allowed_length": 2,
    "dry_penalty_last_n": -1,
    "batch_size": 2048,
    "ubatch_size": 512,
    "parallel": -1,
    "n_cpu_moe": null,
    "fit": "on",
    "flash_attn": "auto",
    "cache_type_k": "f16",
    "cache_type_v": "f16",
    "kv_unified": true,
    "cache_idle_slots": true,
    "backend_sampling": false,
    "web_ui": true,
    "no_warmup": false,
    "no_mmap": false,
    "poll": 50,
    "jinja": true,
    "mmproj_file": "",
    "chat_template_file": "",
    "chat_template_kwargs": "",
    "extra_server_args": []
  },
  "reasoning": {
    "enable": "auto",
    "format": "auto",
    "budget": -1,
    "budget_message": ""
  }
}
