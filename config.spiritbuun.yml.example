# yaml-language-server: $schema=https://raw.githubusercontent.com/mostlygeek/llama-swap/refs/heads/main/config-schema.json
#
# Copy this file to config.spiritbuun.yml for local edits and overrides.
# Use this mode with ./run.sh --mode spiritbuun start when you want the
# spiritbuun/buun-llama-cpp qwen3-chat path with a published DFlash GGUF draft.

healthCheckTimeout: 1800
logLevel: info
sendLoadingState: false
globalTTL: 0

# Shared llama-server argument macros
macros:
  server_bin: "/opt/venv/bin/easyllama"
  llama_server_bin: "/app/bin/llama-server-spiritbuun"
  kv_ctx_size: "262144"
  qwen3_chat_target_hf: "unsloth/Qwen3.6-27B-GGUF:Q5_K_M"
  qwen3_chat_draft_hf: "Ardenzard/Qwen3.6-27B-DFlash-GGUF:Qwen3.6-27B-DFlash-Q5_K_M.gguf"
  pi_emb_hf_model: "Qwen/Qwen3-Embedding-8B-GGUF:Q5_K_M"
  qmd_chat_hf_model: "tobil/qmd-query-expansion-1.7B-gguf:Q8_0"
  qmd_emb_hf_model: "Qwen/Qwen3-Embedding-8B-GGUF:Q5_K_M"
  qmd_rerank_hf_model: "mradermacher/Qwen3-Reranker-8B-GGUF:Q5_K_M"
  n_predict: "8192"
  temp: "0.6"
  chat_temp: "0.2"
  top_k: "20"
  top_p: "0.95"
  min_p: "0.0"
  sampler_seq: "edskypmxt"
  repeat_last_n: "512"
  repeat_penalty: "1.05"
  presence_penalty: "1.5"
  frequency_penalty: "0.0"
  dry_multiplier: "0.0"
  dry_base: "1.75"
  dry_allowed_length: "2"
  dry_penalty_last_n: "2048"
  batch_size: "1024"
  ubatch_size: "256"
  chat_batch_size: "256"
  chat_ubatch_size: "64"
  parallel: "1"
  flash_attn: "on"
  fit: "on"
  cache_type_k: "turbo4"
  cache_type_v: "turbo4"
  poll: "1"
  no_mmap: "--no-mmap"
  kv_unified: "--kv-unified"
  cache_idle_slots: "--cache-idle-slots"
  backend_sampling: "--backend-sampling"
  web_ui_off: "--no-webui"
  jinja_on: "--jinja"
  no_warmup: "--no-warmup"
  mmproj_arg: "${env.LLAMACPP_MMPROJ_ARG}"
  chat_template_file: "/chat_template/qwen3.6.jinja"
  chat_template_kwargs: '{\"tokenize\":false,\"add_generation_prompt\":true,\"enable_thinking\":false,\"preserve_thinking\":false}'
  emb_cache_type_k: "f16"
  emb_cache_type_v: "f16"
  rerank_batch_size: "2048"
  rerank_ubatch_size: "2048"
  rerank_ctx_size: "4096"
  qwen3_chat_draft_context: "256"
  qwen3_chat_draft_max: "8"
  qwen3_chat_draft_min: "1"
  qwen3_chat_draft_p_min: "0.75"
  qwen3_chat_draft_cache_type_k: "f16"
  qwen3_chat_draft_cache_type_v: "f16"
  qwen3_chat_draft_gpu_layers: "all"

models:
  "qwen3-chat":
    name: "Pi Qwen3 Chat 27B Spiritbuun"
    description: "Primary chat/completions model using spiritbuun dflash with a published GGUF draft"
    filters:
      stripParams: "chat_template_kwargs, thinking, thinking_budget_tokens, reasoning"
      setParams:
        reasoning: "off"
        chat_template_kwargs:
          tokenize: false
          add_generation_prompt: true
          enable_thinking: false
          preserve_thinking: false
    cmd: |
      ${server_bin}
      server
      spiritbuun
      --bin ${llama_server_bin}
      --port ${PORT}
      --target-hf ${qwen3_chat_target_hf}
      --draft-hf ${qwen3_chat_draft_hf}
      --ctx-size ${kv_ctx_size}
      --n-predict ${n_predict}
      --temp ${chat_temp}
      --batch-size ${chat_batch_size}
      --ubatch-size ${chat_ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${cache_type_k}
      --cache-type-v ${cache_type_v}
      --cache-type-k-draft ${qwen3_chat_draft_cache_type_k}
      --cache-type-v-draft ${qwen3_chat_draft_cache_type_v}
      --gpu-layers-draft ${qwen3_chat_draft_gpu_layers}
      ${web_ui_off}
      ${no_warmup}
      ${no_mmap}
      --context-shift
      --chat-template-kwargs ${chat_template_kwargs}
      --reasoning off
      -cd ${qwen3_chat_draft_context}
      --draft-max ${qwen3_chat_draft_max}
      --draft-min ${qwen3_chat_draft_min}
      --draft-p-min ${qwen3_chat_draft_p_min}

    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qwen3-embeddings":
    name: "Pi Qwen3 Embeddings 8B"
    description: "Dense embedding model for vector search, RAG, similarity"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${pi_emb_hf_model}
      --ctx-size ${kv_ctx_size}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${kv_unified}
      ${no_mmap}
      --embedding
      ${no_warmup}

    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-generate":
    name: "QMD Query Expansion"
    description: "Alias for QMD query expansion and OpenAI-compatible completions"
    filters:
      stripParams: "chat_template_kwargs, thinking, thinking_budget_tokens, reasoning"
      setParams:
        reasoning: "off"
        chat_template_kwargs:
          tokenize: false
          add_generation_prompt: true
          enable_thinking: false
          preserve_thinking: false
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_chat_hf_model}
      --ctx-size ${kv_ctx_size}
      --n-predict ${n_predict}
      --temp ${temp}
      --top-k ${top_k}
      --top-p ${top_p}
      --min-p ${min_p}
      --sampler-seq ${sampler_seq}
      --repeat-last-n ${repeat_last_n}
      --repeat-penalty ${repeat_penalty}
      --presence-penalty ${presence_penalty}
      --frequency-penalty ${frequency_penalty}
      --dry-multiplier ${dry_multiplier}
      --dry-base ${dry_base}
      --dry-allowed-length ${dry_allowed_length}
      --dry-penalty-last-n ${dry_penalty_last_n}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --fit ${fit}
      --flash-attn ${flash_attn}
      --cache-type-k ${cache_type_k}
      --cache-type-v ${cache_type_v}
      ${kv_unified}
      ${cache_idle_slots}
      ${backend_sampling}
      ${web_ui_off}
      ${no_warmup}
      ${no_mmap}
      --context-shift
      --poll ${poll}
      ${jinja_on}
      --chat-template-file ${chat_template_file}
      --chat-template-kwargs ${chat_template_kwargs}
      --reasoning off

    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-embed":
    name: "QMD Embedding"
    description: "Alias for QMD /v1/embeddings requests"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_emb_hf_model}
      --ctx-size ${kv_ctx_size}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${kv_unified}
      ${no_mmap}
      --embedding
      ${no_warmup}

    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-rerank":
    name: "Qwen3 Reranker 8B"
    description: "Cross-encoder reranking model for QMD /v1/rerank requests"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_rerank_hf_model}
      --ctx-size ${rerank_ctx_size}
      --batch-size ${rerank_batch_size}
      --ubatch-size ${rerank_ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${kv_unified}
      ${no_mmap}
      --reranking
      ${no_warmup}

    env:
      - "HF_TOKEN=${env.HF_TOKEN}"