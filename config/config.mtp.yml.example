# yaml-language-server: $schema=https://raw.githubusercontent.com/mostlygeek/llama-swap/refs/heads/main/config-schema.json
#
# Local runtime configuration template for MTP mode.
# Copy this file to config/config.mtp.yml for local edits and overrides.
# Multi-Token Prediction via am17an/llama.cpp mtp-clean branch.

healthCheckTimeout: 1800
logLevel: info
sendLoadingState: false
globalTTL: 0

macros:
  server_bin: "/opt/venv/bin/easyllama"
  chat_threads: "8"
  chat_threads_batch: "16"
  chat_gpu_layers: "99"
  llama_server_bin: "/app/bin/llama-server-mtp"
  chat_ctx_size: "131072"
  qmd_ctx_size: "131072"
  qwen3_chat_target_hf: "havenoammo/Qwen3.6-27B-MTP-UD-GGUF:Qwen3.6-27B-MTP-UD-Q5_K_XL.gguf"
  pi_emb_hf_model: "Qwen/Qwen3-Embedding-8B-GGUF:Q5_K_M"
  qmd_chat_hf_model: "tobil/qmd-query-expansion-1.7B-gguf:Q8_0"
  qmd_emb_hf_model: "Qwen/Qwen3-Embedding-8B-GGUF:Q5_K_M"
  qmd_rerank_hf_model: "mradermacher/Qwen3-Reranker-8B-GGUF:Q5_K_M"
  n_predict: "-1"
  temp: "0.7"
  top_k: "20"
  top_p: "0.80"
  min_p: "0.0"
  sampler_seq: "edskypmxt"
  repeat_last_n: "512"
  repeat_penalty: "1.0"
  presence_penalty: "1.5"
  frequency_penalty: "0.0"
  dry_multiplier: "0.0"
  dry_base: "1.75"
  dry_allowed_length: "2"
  dry_penalty_last_n: "512"
  batch_size: "2048"
  ubatch_size: "1024"
  parallel: "1"
  flash_attn: "on"
  fit: "off"
  cache_type_k: "q8_0"
  cache_type_v: "q8_0"
  poll: "0"
  poll_batch: "0"
  no_mmap: "--no-mmap"
  web_ui_off: "--no-webui"
  no_warmup: "--no-warmup"
  jinja_on: "--jinja"
  chat_template_file: "/chat_template/qwen3.6.jinja"
  chat_template_kwargs: '{\"tokenize\":false,\"add_generation_prompt\":true,\"enable_thinking\":false,\"preserve_thinking\":false}'
  emb_cache_type_k: "f16"
  emb_cache_type_v: "f16"
  rerank_batch_size: "2048"
  rerank_ubatch_size: "2048"
  rerank_ctx_size: "4096"
  spec_type: "mtp"
  spec_draft_n_max: "3"

models:
  "qwen3-chat":
    name: "Pi Qwen3 Chat 27B MTP"
    description: "Primary chat/completions model with MTP speculative decoding (2x+ throughput)"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      --threads ${chat_threads}
      --threads-batch ${chat_threads_batch}
      -hf ${qwen3_chat_target_hf}
      --ctx-size ${chat_ctx_size}
      --n-predict ${n_predict}
      --temp ${temp}
      --top-k ${top_k}
      --top-p ${top_p}
      --min-p ${min_p}
      --sampler-seq ${sampler_seq}
      --repeat-last-n ${repeat_last_n}
      --repeat-penalty ${repeat_penalty}
      --presence-penalty ${presence_penalty}
      --frequency-penalty ${frequency_penalty}
      --dry-multiplier ${dry_multiplier}
      --dry-base ${dry_base}
      --dry-allowed-length ${dry_allowed_length}
      --dry-penalty-last-n ${dry_penalty_last_n}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --fit ${fit}
      --gpu-layers ${chat_gpu_layers}
      --flash-attn ${flash_attn}
      --cache-type-k ${cache_type_k}
      --cache-type-v ${cache_type_v}
      --spec-type ${spec_type}
      --spec-draft-n-max ${spec_draft_n_max}
      ${web_ui_off}
      ${no_mmap}
      --poll ${poll}
      --poll-batch ${poll_batch}
      --chat-template-kwargs ${chat_template_kwargs}
    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qwen3-embeddings":
    name: "Pi Qwen3 Embeddings 8B"
    description: "Dense embedding model for vector search, RAG, similarity"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${pi_emb_hf_model}
      --ctx-size ${qmd_ctx_size}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${no_mmap}
      --embedding
      ${no_warmup}
    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-generate":
    name: "QMD Query Expansion"
    description: "Alias for QMD query expansion and OpenAI-compatible completions"
    filters:
      setParams:
        reasoning: "off"
        chat_template_kwargs:
          tokenize: false
          add_generation_prompt: true
          enable_thinking: false
          preserve_thinking: false
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_chat_hf_model}
      --ctx-size ${qmd_ctx_size}
      --n-predict ${n_predict}
      --temp ${temp}
      --top-k ${top_k}
      --top-p ${top_p}
      --min-p ${min_p}
      --sampler-seq ${sampler_seq}
      --repeat-last-n ${repeat_last_n}
      --repeat-penalty ${repeat_penalty}
      --presence-penalty ${presence_penalty}
      --frequency-penalty ${frequency_penalty}
      --dry-multiplier ${dry_multiplier}
      --dry-base ${dry_base}
      --dry-allowed-length ${dry_allowed_length}
      --dry-penalty-last-n ${dry_penalty_last_n}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --fit ${fit}
      --flash-attn ${flash_attn}
      --cache-type-k ${cache_type_k}
      --cache-type-v ${cache_type_v}
      ${web_ui_off}
      ${no_warmup}
      ${no_mmap}
      --poll ${poll}
      ${jinja_on}
      --chat-template-file ${chat_template_file}
      --chat-template-kwargs ${chat_template_kwargs}
      --reasoning off
    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-embed":
    name: "QMD Embedding"
    description: "Alias for QMD /v1/embeddings requests"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_emb_hf_model}
      --ctx-size ${qmd_ctx_size}
      --batch-size ${batch_size}
      --ubatch-size ${ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${no_mmap}
      --embedding
      ${no_warmup}
    env:
      - "HF_TOKEN=${env.HF_TOKEN}"

  "qmd-rerank":
    name: "Qwen3 Reranker 8B"
    description: "Cross-encoder reranking model for QMD /v1/rerank requests"
    cmd: |
      ${server_bin}
      server
      basic
      --bin ${llama_server_bin}
      --port ${PORT}
      -hf ${qmd_rerank_hf_model}
      --ctx-size ${rerank_ctx_size}
      --batch-size ${rerank_batch_size}
      --ubatch-size ${rerank_ubatch_size}
      --parallel ${parallel}
      --flash-attn ${flash_attn}
      --cache-type-k ${emb_cache_type_k}
      --cache-type-v ${emb_cache_type_v}
      ${no_mmap}
      --reranking
      ${no_warmup}
    env:
      - "HF_TOKEN=${env.HF_TOKEN}"
